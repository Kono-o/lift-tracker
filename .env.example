# Copy to .env and fill in from Supabase Dashboard → Project Settings → API.
# Never commit .env or paste the service role key into the frontend.

PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Capacitor native OAuth — add this redirect URL in Supabase Auth → URL configuration:
#   com.lifttracker.app://auth/callback
#
# Optional live reload while developing in Android Studio / Xcode:
#   CAPACITOR_DEV_SERVER_URL=http://YOUR_LAN_IP:5173 npm run cap:sync
#
# Signed sideload APK (after scripts/setup-android-signing.fish):
#   npm run build:apk:release

# Server-only (Vercel / local dev). Required for account deletion API.
# Dashboard → API → service_role — keep private.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here