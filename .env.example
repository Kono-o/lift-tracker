# Copy to .env and fill in from Supabase Dashboard → Project Settings → API.
# Never commit .env or paste the service role key into the frontend.

PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only (Vercel / local dev). Required for account deletion API.
# Dashboard → API → service_role — keep private.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here