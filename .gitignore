# Dependencies
node_modules

# SvelteKit / Vite build output
.svelte-kit
.output
build
dist
all

# Capacitor native projects (generated via npm run cap:add:*)
android
ios

# Android release signing (generate locally; never commit secrets)
android-signing/keystore.properties
android-signing/*.keystore

# Deployment platform metadata (may contain project ids)
.vercel
.netlify
.wrangler

# Environment & secrets (never commit real keys)
.env
.env.*
!.env.example

# Supabase CLI local state (not your cloud project)
supabase/.branches
supabase/.temp
supabase/.env

# Logs & debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage
coverage

# TypeScript
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Misc caches
.cache
.turbo
*.pem
*.key
*.p12

# Local helper / personal scripts (not part of the shared project)
setup-db.fish
*.local.fish
local-*.fish
reset-db.fish
supabase-local.*