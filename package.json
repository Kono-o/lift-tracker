{
	"name": "lift-tracker",
	"description": "Workout logging app with templates, timed exercises, stats, and Supabase sync",
	"private": true,
	"version": "0.0.1",
	"homepage": "https://lift-tracker-self.vercel.app",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Kono-o/lift-tracker.git"
	},
	"bugs": {
		"url": "https://github.com/Kono-o/lift-tracker/issues"
	},
	"type": "module",
	"scripts": {
		"dev": "vite dev --host 0.0.0.0",
		"dev:phone": "./scripts/dev-phone.fish",
		"dev:tunnel": "./scripts/dev-phone.fish --tunnel",
		"build": "vite build",
		"build:capacitor": "CAPACITOR=1 vite build",
		"preview": "vite preview",
		"cap:sync": "npm run build:capacitor && npx cap sync",
		"cap:open:android": "npx cap open android",
		"cap:open:ios": "npx cap open ios",
		"cap:add:android": "npx cap add android",
		"cap:add:ios": "npx cap add ios",
		"build:apk:release": "./scripts/build-release-apk.fish",
		"db:setup": "./scripts/setup-db.fish",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@capacitor/cli": "^8.4.0",
		"@fontsource-variable/oxanium": "^5.2.8",
		"@lucide/svelte": "^1.17.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.9.2",
		"clsx": "^2.1.1",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@capacitor/android": "^8.4.0",
		"@capacitor/app": "^8.1.0",
		"@capacitor/core": "^8.4.0",
		"@capacitor/keyboard": "^8.0.3",
		"@capacitor/splash-screen": "^8.0.1",
		"@capacitor/status-bar": "^8.0.2",
		"@fontsource/dseg7-classic": "^5.2.5",
		"@fontsource/space-mono": "^5.2.9",
		"@supabase/supabase-js": "^2.107.0"
	}
}
